{
  "name": "digiaduana",
  "version": "1.0.0",
  "description": "Plataforma web para automatizar procesos aduaneros de Freight Forwarders en El Salvador.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -k -n API,WEB -c blue,green \"nodemon server.js\" \"vite --host 0.0.0.0\"",
    "api:dev": "nodemon server.js",
    "frontend:dev": "vite --host 0.0.0.0",
    "frontend:build": "vite build",
    "db:seed": "mysql -u root -p < database/schema.sql",
    "db:test-data": "mysql -u root -p < database/seed_test_data.sql"
  },
  "keywords": [
    "aduanas",
    "freight-forwarder",
    "node",
    "mysql",
    "dte"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "pinia": "^2.3.1",
    "vite": "^6.3.5",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
