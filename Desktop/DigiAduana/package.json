{
  "name": "digiaduana-workspace",
  "private": true,
  "scripts": {
    "install:app": "npm --prefix DigiAduana install",
    "dev": "npm --prefix DigiAduana run dev",
    "api:dev": "npm --prefix DigiAduana run api:dev",
    "frontend:dev": "npm --prefix DigiAduana run frontend:dev",
    "frontend:build": "npm --prefix DigiAduana run frontend:build",
    "start": "npm --prefix DigiAduana start",
